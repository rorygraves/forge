{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.io/schemas/design-review.json",
  "title": "DesignReview",
  "description": "Schema for forge design-review outputs (§7.1 / §10.2). Mirrors DesignReview / ReviewBlocker / Question in forge-agents/Reviews.scala. Used by both reviewer connectors via Claude --json-schema and Codex --output-schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "blockers", "questions", "summary"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "request_changes"],
      "description": "Top-level review outcome."
    },
    "blockers": {
      "type": "array",
      "description": "Inline blockers tied to specific design sections; empty when verdict=approve.",
      "items": { "$ref": "#/$defs/blocker" }
    },
    "questions": {
      "type": "array",
      "description": "Design questions; only blocking severity transitions the FSM to DesignNeedsHumanInput.",
      "items": { "$ref": "#/$defs/question" }
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary; rendered as the top-level review comment."
    }
  },
  "$defs": {
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "path", "line", "anchorText"],
      "properties": {
        "summary": { "type": "string" },
        "path": { "type": ["string", "null"] },
        "line": { "type": ["integer", "null"] },
        "anchorText": { "type": ["string", "null"] }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "options", "allowFreeText", "severity"],
      "properties": {
        "text": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowFreeText": { "type": ["boolean", "null"] },
        "severity": {
          "type": "string",
          "enum": ["blocking", "clarifying", "optional"]
        }
      }
    }
  }
}
