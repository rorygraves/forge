{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.io/schemas/refine.json",
  "title": "RefineResult",
  "description": "Schema for forge refine outputs (§14.3). Mirrors RefineResult in forge-agents/Reviews.scala. `patch` is always present and nullable (a ManifestPatch when outcome == 'update_plan', null otherwise); the 'patch present iff update_plan' invariant is enforced by ReviewDecoders.refineResult rather than the schema, because Codex's --output-schema (OpenAI strict mode) forbids the if/then/allOf keywords that would express it and requires every property in `required` (design-rationale C17). ManifestPatchOp variants carry a `$type` discriminator (uPickle wire shape).",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome", "reason", "patch"],
  "properties": {
    "outcome": {
      "type": "string",
      "enum": ["no_change", "update_plan", "reopen_design"],
      "description": "Per §14.3: NoChange leaves the manifest untouched; UpdatePlan carries a ManifestPatch; ReopenDesign sends the feature back to DesignReviewing."
    },
    "reason": {
      "type": "string",
      "description": "Human-readable rationale for the chosen outcome."
    },
    "patch": {
      "description": "ManifestPatch when outcome == update_plan; null otherwise. The 'patch present iff update_plan' invariant (§14.3) is enforced by ReviewDecoders.refineResult, not the schema — Codex's --output-schema (OpenAI strict mode) forbids the conditional if/then/allOf keywords that would express it here (design-rationale C17).",
      "anyOf": [
        { "$ref": "#/$defs/manifestPatch" },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "manifestPatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "ops"],
      "properties": {
        "reason": { "type": "string" },
        "ops": {
          "type": "array",
          "items": { "$ref": "#/$defs/manifestPatchOp" }
        }
      }
    },
    "manifestPatchOp": {
      "anyOf": [
        { "$ref": "#/$defs/op_addPiece" },
        { "$ref": "#/$defs/op_removePiece" },
        { "$ref": "#/$defs/op_editPiece" },
        { "$ref": "#/$defs/op_reorderPieces" }
      ]
    },
    "op_addPiece": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$type", "after", "piece"],
      "properties": {
        "$type": { "type": "string", "const": "AddPiece" },
        "after": { "type": ["string", "null"] },
        "piece": { "$ref": "#/$defs/piece" }
      }
    },
    "op_removePiece": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$type", "id"],
      "properties": {
        "$type": { "type": "string", "const": "RemovePiece" },
        "id": { "type": "string" }
      }
    },
    "op_editPiece": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$type", "id", "title", "summary", "specPath", "acceptanceHash"],
      "properties": {
        "$type": { "type": "string", "const": "EditPiece" },
        "id": { "type": "string" },
        "title": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] },
        "specPath": { "type": ["string", "null"] },
        "acceptanceHash": { "type": ["string", "null"] }
      }
    },
    "op_reorderPieces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$type", "newOrder"],
      "properties": {
        "$type": { "type": "string", "const": "ReorderPieces" },
        "newOrder": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "piece": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "order", "title", "summary", "specPath",
        "acceptanceHash", "status", "baseSha", "prNumber",
        "mergeCommit", "mergedAt", "attempts"
      ],
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "integer" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "specPath": { "type": "string" },
        "acceptanceHash": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "merged"]
        },
        "baseSha": { "type": ["string", "null"] },
        "prNumber": { "type": ["integer", "null"] },
        "mergeCommit": { "type": ["string", "null"] },
        "mergedAt": { "type": ["string", "null"] },
        "attempts": { "type": "integer" }
      }
    }
  }
}
